# 管理后台密码（必填）
ADMIN_PASSWORD=your_admin_password

# DeepSeek API - 文本对话/设计、解析降级
DEEPSEEK_API_KEY=sk-xxx

# 火山引擎 - 豆包解析、即梦图像（二期）
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

